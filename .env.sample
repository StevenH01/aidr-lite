# ============================================================
# AIDR-Lite environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# ---- Backend -----------------------------------------------

# Port the FastAPI backend listens on
BACKEND_PORT=8000

# Shared secret validated on every ingest request (X-API-Key header).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
BACKEND_API_KEY=change_me_generate_a_real_secret

# SQLite database path (Phase 5). For Postgres swap this for a full DSN.
DATABASE_URL=sqlite:///./aidr.db

# Set to "true" in dev/lab to enable /docs (Swagger UI).
# Leave unset or "false" in production.
AIDR_DOCS_ENABLED=false

# ---- Agent -------------------------------------------------

# Unique identifier for this endpoint. Alphanumeric, hyphens, dots allowed.
AGENT_HOST_ID=ubuntu-lab-01

# Full URL of the backend ingest endpoint
AGENT_INGEST_URL=http://localhost:8000/api/events

# Must match BACKEND_API_KEY above
AGENT_API_KEY=change_me_generate_a_real_secret

# Path to syslog auth file (Ubuntu default shown)
AGENT_AUTH_LOG=/var/log/auth.log

# How often (seconds) the network collector polls for new connections
AGENT_NETWORK_POLL=30

# How often (seconds) the filesystem collector checks sensitive files
AGENT_FILE_CHECK_SECONDS=60

# ---- Dashboard (Phase 5+) ----------------------------------

# Backend base URL as seen by the dashboard's browser client
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
